#. Template: AdminCustomerDashboardInfoTile
msgid "Customer Dashboard Info Tile"
msgstr "Ügyfél vezérlőpultján lévő információs csempe"

#. Template: AdminCustomerDashboardInfoTile
msgid "Customer Dashboard Info Tile Management"
msgstr "Ügyfél vezérlőpultján lévő információs csempe kezelése"

#. Template: AdminCustomerDashboardInfoTile
msgid "Create new info tile entry"
msgstr "Új információs csempe bejegyzés létrehozása"

#. Template: AdminCustomerDashboardInfoTile
msgid "Filter for info tile entries"
msgstr "Szűrő az információs csempe bejegyzéseihez"

#. Template: AdminCustomerDashboardInfoTile
msgid ""
"Create a new entry to be displayed on the info tile on the customer "
"dashboard."
msgstr ""
"Az ügyfél vezérlőpultján lévő információs csempén megjelenítendő új "
"bejegyzés létrehozása."

#. Template: AdminCustomerDashboardInfoTile
msgid "Delete info tile entry"
msgstr "Információs csempe bejegyzés törlése"

#. Template: AdminCustomerDashboardInfoTileEdit
msgid "Edit customer dashboard info tile entry"
msgstr ""
"Az ügyfél vezérlőpultján lévő információs csempe bejegyzésének szerkesztése"

#. Template: AdminCustomerDashboardInfoTileEdit
msgid "Tile content"
msgstr "Csempe tartalma"

#. Template: AdminCustomerDashboardInfoTileEdit
msgid "Content Body"
msgstr "Tartalom törzse"

#. Template: AdminCustomerDashboardInfoTileEdit
msgid "Marquee content"
msgstr "Tartalom futószövegként való megjelenítése"

#. Template: AdminCustomerDashboardInfoTileEdit
msgid "Group Selection"
msgstr "Kijelölés csoportosítása"

#. Template: AdminCustomerDashboardInfoTileNew
msgid "Create new customer dashboard info tile entry"
msgstr ""
"Az ügyfél vezérlőpultján lévő információs csempe új bejegyzésének létrehozása"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "Name is missing!"
msgstr "A név hiányzik!"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "Content is missing!"
msgstr "A tartalom hiányzik!"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "ValidID is missing!"
msgstr "Az érvényességazonosító hiányzik!"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "Group is missing!"
msgstr "A csoport hiányzik!"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "There was an error creating the info tile entry"
msgstr "Hiba történt az információs csempe bejegyzésének létrehozásakor"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "Need ID!"
msgstr "Azonosító szükséges!"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid ""
"This Entry does not exist, or you don't have permissions to access it in its "
"current state."
msgstr ""
"Ez a bejegyzés nem létezik, vagy nincs jogosultsága a hozzáféréshez annak "
"jelenlegi állapotában."

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "Could not get data for ID %s"
msgstr "Nem sikerült lekérni az adatokat az azonosítóhoz: %s"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "Info tile entry was added successfully!"
msgstr "Az információs csempe bejegyzése sikeresen hozzá lett adva!"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "Info tile entry was updated successfully!"
msgstr "Az információs csempe bejegyzése sikeresen frissítve lett!"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "There was an error updating the info tile entry"
msgstr "Hiba történt az információs csempe bejegyzésének frissítésekor"

#. Perl Module: Kernel/Modules/AdminCustomerDashboardInfoTile.pm
msgid "It was not possible to delete the info tile entry: %s!"
msgstr "Nem volt lehetséges az információs csempe bejegyzésének törlése: %s!"

#. JS File: Core.Agent.Admin.CustomerDashboardInfoTile
msgid "Do you really want to delete this customer dashboard info tile entry?"
msgstr ""
"Valóban törölni szeretné az ügyfél vezérlőpultján lévő információs csempe "
"bejegyzését?"

#. SysConfig
msgid "CustomerDashboard Info Tile"
msgstr "Ügyfél vezérlőpultján lévő információs csempe"

#. SysConfig
msgid ""
"Defines the module to display a notification in the customer interface. "
"UseMarquee options: 1/0. NotifyPriority options: Notice/Error/Success/Info."
msgstr ""
"Meghatározza azt a modult, amely egy értesítést jelenít meg az "
"ügyfélfelületen. A „UseMarquee” lehetőségei: 1 vagy 0. A „NotifyPriority” "
"lehetőségei: „Notice”, „Error”, „Success”, „Info”."

#. SysConfig
msgid "Frontend module for dashboard info tile in customer interface."
msgstr ""
"Előtétprogram-modul a vezérlőpulton lévő információs csempéhez az "
"ügyfélfelületen."

#. SysConfig
msgid "Loader module for dashboard info tile in customer interface."
msgstr ""
"Betöltőmodul a vezérlőpulton lévő információs csempéhez az ügyfélfelületen."

#. SysConfig
msgid "Manage Customer Dashboard Info Tile Entries"
msgstr "Vezérlőpulton lévő információs csempe bejegyzéseinek kezelése"

#. SysConfig
msgid ""
"Tile registration for the CustomerDashboard. Module is required. Optionally, "
"an order for items can be set. The order must have the name of the item as "
"key and the desired position as integer value."
msgstr ""
"Csemperegisztráció az ügyfél vezérlőpultjához. A modul kötelező. "
"Választhatóan beállítható az elemek sorrendje. A sorrendnek az elem nevét "
"kell tartalmaznia kulcsként és a kívánt helyzetet egész szám értékként."
